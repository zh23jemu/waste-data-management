# Python 本地虚拟环境和缓存目录只用于本机开发，不应进入项目版本记录。
.venv/
__pycache__/
*.py[cod]
.pytest_cache/
.mypy_cache/
.ruff_cache/
.codex_tmp/
.codex_tmp_*
.recallloom/.tmp_*

# 模型权重、训练数据和向量库运行态通常体积较大或依赖本机环境，不纳入版本记录。
data/raw/
data/processed/
Garbage Classification (12 classes).zip
models/*.pt
models/*.pth
models/*.onnx
outputs/
qdrant_storage/
uploads/
instance/

# 本地环境变量、日志和系统生成文件通常包含机器相关信息或临时内容。
.env
.env.*
!.env.example
*.log
Thumbs.db
.DS_Store
wget-log*
