# Flask 基础配置
FLASK_ENV=development
SECRET_KEY=change-me
DATABASE_PATH=instance/waste_management.sqlite3
UPLOAD_FOLDER=uploads
MAX_CONTENT_LENGTH=16777216

# 模型与向量检索配置
MODEL_PATH=models/resnet50_waste.pt
CLASS_MAP_PATH=models/class_map.json
QDRANT_URL=http://localhost:6333
QDRANT_COLLECTION=waste_images
SIMILARITY_THRESHOLD=0.65

# DeepSeek 真实 API 配置
DEEPSEEK_API_KEY=
DEEPSEEK_BASE_URL=https://api.deepseek.com/chat/completions
DEEPSEEK_MODEL=deepseek-chat

# 星火图片理解真实 API 配置
# 不同账号/版本的星火视觉接口地址可能不同，因此接口地址显式配置。
XUNFEI_APP_ID=
XUNFEI_API_KEY=
XUNFEI_API_SECRET=
XUNFEI_VISION_URL=
