# Flask 基础配置
FLASK_ENV=development
SECRET_KEY=change-me
DATABASE_PATH=instance/waste_management.sqlite3
UPLOAD_FOLDER=uploads
MAX_CONTENT_LENGTH=16777216

# 模型与向量检索配置
MODEL_PATH=models/resnet50_waste.pt
CLASS_MAP_PATH=models/class_map.json
QDRANT_URL=http://localhost:6333
QDRANT_COLLECTION=waste_images
SIMILARITY_THRESHOLD=0.65

# DeepSeek 真实 API 配置
DEEPSEEK_API_KEY=
DEEPSEEK_BASE_URL=https://api.deepseek.com/chat/completions
DEEPSEEK_MODEL=deepseek-chat

# Kimi 多模态图片理解真实 API 配置
KIMI_API_KEY=
KIMI_BASE_URL=https://api.moonshot.cn/v1/chat/completions
KIMI_MODEL=kimi-k2.6
